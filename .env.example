# Public application origin, without a trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Generated by `bun run register:chutes`. The registration API key is never
# stored by this application.
CHUTES_OAUTH_CLIENT_ID=
CHUTES_OAUTH_CLIENT_SECRET=
CHUTES_OAUTH_SCOPES=openid profile chutes:invoke
CHUTES_IDP_BASE_URL=https://api.chutes.ai

# Convex deployment values created by `bunx convex dev`.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# ES256 signing key used only by Next.js. Use a private JWK JSON value.
AUTH_JWT_PRIVATE_JWK=
AUTH_JWT_ISSUER=http://localhost:3000
AUTH_JWT_AUDIENCE=siap-convex
AUTH_JWT_KID=siap-local-1

# Optional model overrides. The live ensemble requires four distinct models
# with confidential_compute=true and structured_outputs support.
CHUTES_PRIMARY_MODEL=google/gemma-4-31B-turbo-TEE
CHUTES_MAPPER_MODEL=MiniMaxAI/MiniMax-M2.5-TEE
CHUTES_REVIEW_MODEL=deepseek-ai/DeepSeek-V3.2-TEE
CHUTES_PLANNER_MODEL=zai-org/GLM-5-TEE

# Set only while intentionally running the paid live smoke test.
RUN_CHUTES_SMOKE_TEST=false
# Optional direct short-lived OAuth token. When omitted, the smoke test reads
# the HttpOnly access cookie from E2E_AUTH_STATE.
CHUTES_SMOKE_ACCESS_TOKEN=
# Playwright storage state captured after an intentional Chutes sign-in.
E2E_AUTH_STATE=
# Optional deployed origin for production browser verification.
E2E_BASE_URL=

# Set these on the Convex deployment (not in Vercel):
# AUTH_JWT_ISSUER=http://localhost:3000
# AUTH_JWT_AUDIENCE=siap-convex
# AUTH_JWKS_DATA_URI=data:text/plain;charset=utf-8;base64,<public JWKS>
